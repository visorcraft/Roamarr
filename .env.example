# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
# Required: the app refuses to boot without it.
ROAMARR_SECRET=
# MongrelDB Kit data directory.
MONGREL_DATABASE_PATH=./roamarr.kitdb
# Optional attachments directory. Defaults to <MONGREL_DATABASE_PATH>/attachments.
ATTACHMENTS_PATH=
PORT=3000
ORIGIN=https://roamarr.example.com
