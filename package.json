{
	"name": "roamarr",
	"private": true,
	"version": "0.5.0",
	"license": "GPL-3.0-only",
	"type": "module",
	"engines": {
		"node": ">=22.12"
	},
	"scripts": {
		"dev": "node --env-file-if-exists=.env ./node_modules/vite/bin/vite.js dev",
		"build": "vite build",
		"start": "node --env-file-if-exists=.env build",
		"preview": "node --env-file-if-exists=.env ./node_modules/vite/bin/vite.js preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"credits:generate": "node scripts/generate-license-data.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/luxon": "^3.7.2",
		"@types/nodemailer": "^8.0.1",
		"@types/qrcode": "^1.5.6",
		"@types/unzipper": "^0.10.11",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@node-rs/argon2": "^2.0.2",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.2",
		"@visorcraft/mongreldb": "^0.20.0",
		"@visorcraft/mongreldb-kit": "^0.8.0",
		"luxon": "^3.7.2",
		"maplibre-gl": "^5.24.0",
		"nodemailer": "^9.0.1",
		"otpauth": "^9.5.1",
		"qrcode": "^1.5.4",
		"tar-fs": "^2.1.5",
		"three": "^0.185.0",
		"unzipper": "^0.12.5"
	},
	"overrides": {
		"cookie": "^0.7.0",
		"@esbuild-kit/core-utils": {
			"esbuild": "^0.25.0"
		}
	}
}
