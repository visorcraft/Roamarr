# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
# Required: the app refuses to boot without it.
# This key also encrypts the MongrelDB Kit database at rest and stored
# credentials (SMTP passwords, tile API keys, etc.). Keep it secret and stable;
# losing it renders the database permanently unreadable.
ROAMARR_SECRET=
# MongrelDB Kit data directory.
MONGREL_DATABASE_PATH=./roamarr.kitdb
# Optional attachments directory. Defaults to <MONGREL_DATABASE_PATH>/attachments.
ATTACHMENTS_PATH=
PORT=3000
# Public origin for cookies/redirects behind proxies. WebAuthn/passkeys require
# this to be set to the HTTPS origin users see.
ORIGIN=https://roamarr.example.com
# NOTE: SMTP (admin server and per-user overrides) is configured in the Roamarr
# web UI, not via environment variables. Admin settings live under /settings once
# logged in; users can add a personal SMTP override under /profile/notifications.
